              "content": "def add(a, b):\n    return a + b\n\n\ndef multiply(a, b):\n    return a * b\n\n\ndef mean(numbers):\n    if not numbers:\n        raise ValueError(\"Cannot compute mean of empty sequence\")\n    return sum(numbers) / len(numbers)\n"
