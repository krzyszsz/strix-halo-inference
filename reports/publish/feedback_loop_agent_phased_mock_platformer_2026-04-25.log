                "stderr": "127.0.0.1 - - [25/Apr/2026 17:17:07] \"GET /index.html HTTP/1.1\" 200 -\n127.0.0.1 - - [25/Apr/2026 17:17:07] \"GET /style.css HTTP/1.1\" 200 -\n127.0.0.1 - - [25/Apr/2026 17:17:07] \"GET /game.js HTTP/1.1\" 200 -\n127.0.0.1 - - [25/Apr/2026 17:17:07] \"GET /levels/level1.txt HTTP/1.1\" 200 -\n127.0.0.1 - - [25/Apr/2026 17:17:07] \"GET /actors/level1.json HTTP/1.1\" 200 -\n",
