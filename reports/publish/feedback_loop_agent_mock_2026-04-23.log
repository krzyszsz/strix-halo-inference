          "plan_note": "Added persistence loading and unit tests after review.",
          "files": [
            {
              "path": "task_tracker.py",
              "content": "import json\nfrom pathlib import Path\n\nclass TaskTracker:\n    def __init__(self):\n        self.tasks = []\n\n    def add(self, title):\n        if not title.strip():\n            raise ValueError('title is required')\n        self.tasks.append({'title': title, 'done': False})\n\n    def done(self, index):\n        self.tasks[index]['done'] = True\n\n    def save(self, path):\n        Path(path).write_text(json.dumps(self.tasks, indent=2), encoding='utf-8')\n\n    def load(self, path):\n        self.tasks = json.loads(Path(path).read_text(encoding='utf-8'))\n"
            },
            {
              "path": "test_task_tracker.py",
              "content": "import tempfile\nimport unittest\nfrom task_tracker import TaskTracker\n\nclass TaskTrackerTests(unittest.TestCase):\n    def test_save_load_roundtrip(self):\n        tracker = TaskTracker()\n        tracker.add('write docs')\n        tracker.done(0)\n        with tempfile.NamedTemporaryFile() as f:\n            tracker.save(f.name)\n            loaded = TaskTracker()\n            loaded.load(f.name)\n        self.assertEqual(loaded.tasks, [{'title': 'write docs', 'done': True}])\n\nif __name__ == '__main__':\n    unittest.main()\n"
            }
          ],
          "commands": [
            [
              "python",
              "-m",
              "unittest",
              "-v"
            ]
          ]
